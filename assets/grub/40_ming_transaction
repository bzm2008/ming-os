#!/bin/sh
# grub-mkconfig_lib deliberately probes optional variables. A fresh installed
# target does not define all of them, so nounset would leave grub.cfg.new
# behind instead of committing the regenerated configuration.
set -e

prefix=/usr
exec_prefix=/usr
datarootdir=/usr/share
. "${datarootdir}/grub/grub-mkconfig_lib"

device="$(grub-probe --target=device /)"
uuid="$(grub-probe --target=fs_uuid /)"
access="$(prepare_grub_to_access_device "${device}" | sed 's/^/    /')"

cat <<EOF
menuentry 'Ming OS Legacy Root' --id 'ming-legacy' {
${access}
    linux /vmlinuz root=UUID=${uuid} ro quiet splash loglevel=0 systemd.show_status=false rd.systemd.show_status=false rd.udev.log_level=0 ming.entry=ming-legacy ming.slot=legacy
    initrd /initrd.img
}
menuentry 'Ming OS Slot A' --id 'ming-slot-a' {
${access}
    linux /vmlinuz root=UUID=${uuid} ro quiet splash loglevel=0 systemd.show_status=false rd.systemd.show_status=false rd.udev.log_level=0 ming.entry=ming-slot-a ming.slot=A
    initrd /initrd.img
}
menuentry 'Ming OS Slot B' --id 'ming-slot-b' {
${access}
    linux /vmlinuz root=UUID=${uuid} ro quiet splash loglevel=0 systemd.show_status=false rd.systemd.show_status=false rd.udev.log_level=0 ming.entry=ming-slot-b ming.slot=B
    initrd /initrd.img
}
menuentry 'Ming OS Recovery (previous committed root)' --id 'ming-recovery-manual' {
${access}
    linux /vmlinuz root=UUID=${uuid} ro ming.slot=legacy ming.recovery=manual
    initrd /initrd.img
}
EOF
