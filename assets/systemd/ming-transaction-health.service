[Unit]
Description=Ming OS transactional update health confirmation
After=local-fs.target dbus.service NetworkManager.service
Before=display-manager.service graphical.target
ConditionPathExists=/var/lib/ming-update/active-transaction.json

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/ming-transaction-health confirm-active
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
