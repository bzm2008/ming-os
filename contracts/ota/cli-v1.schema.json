{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ming.scallion.uno/contracts/ota/cli-v1.schema.json",
  "title": "Ming OS OTA CLI v1 envelope",
  "x-ming-schema-name": "ming.update.cli.v1",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "ming.update.cli.v1" },
    "ok": { "type": "boolean" },
    "command": { "enum": ["status", "check", "apply", "cancel", "doctor", "logs"] },
    "exit_code": { "enum": [0, 2, 3, 4, 5, 6, 7, 8, 9, 10] },
    "error_code": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^E_[A-Z_]+$" }
      ]
    },
    "state": {
      "enum": [
        "new", "verified", "staging", "staged", "armed", "booting",
        "pending_health", "committing", "committed", "aborting", "aborted",
        "rollback_armed", "rolling_back", "rolled_back", "idle", "failed", "available", "bootstrap-required"
      ]
    },
    "transaction": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/transaction" }
      ]
    },
    "update": { "$ref": "#/$defs/update" },
    "action": { "enum": ["none", "check", "bootstrap", "apply", "cancel", "reboot", "wait"] },
    "progress": { "$ref": "#/$defs/progress" },
    "requires_reboot": { "type": "boolean" },
    "message_key": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
    "message_args": { "type": "object" },
    "log_path": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^/var/log/ming-update(?:/.*)?$" }
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "bootstrap": { "$ref": "#/$defs/bootstrap" }
  },
  "required": [
    "schema", "ok", "command", "exit_code", "error_code", "state",
    "transaction", "update", "action", "progress", "requires_reboot",
    "message_key", "message_args", "log_path", "timestamp"
  ],
  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } } },
      "then": {
        "properties": {
          "exit_code": { "const": 0 },
          "error_code": { "type": "null" }
        }
      },
      "else": {
        "properties": {
          "exit_code": { "enum": [2, 3, 4, 5, 6, 7, 8, 9, 10] },
          "error_code": { "type": "string", "pattern": "^E_[A-Z_]+$" }
        }
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "releaseId": { "type": "string", "pattern": "^[A-Za-z0-9._-]{8,128}$" },
    "version": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+){1,3}(?:[A-Za-z0-9._-]+)?$" },
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://[^/?#@]+(?:/[^?#]*)?$" },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]{3,128}$" },
        "release_id": { "$ref": "#/$defs/releaseId" },
        "previous_slot": { "enum": ["legacy", "A", "B"] },
        "candidate_slot": { "enum": ["A", "B"] },
        "generation": { "type": "integer", "minimum": 1 }
      },
      "required": ["id", "release_id", "previous_slot", "candidate_slot", "generation"]
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_version": { "$ref": "#/$defs/version" },
        "available_version": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/version" }] },
        "release_id": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/releaseId" }] },
        "delivery": { "enum": ["none", "bootstrap", "transactional-slot-v1", "recovery-iso"] },
        "manifest_sha256": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }] },
        "release_notes": { "type": "string" }
      },
      "required": ["current_version", "available_version", "release_id", "delivery", "manifest_sha256"]
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phase": {
          "enum": ["idle", "discovery", "verifying", "staging", "armed", "booting", "pending-health", "committing", "rolled-back", "complete"]
        },
        "percent": { "type": "integer", "minimum": 0, "maximum": 100 }
      },
      "required": ["phase", "percent"]
    },
    "bootstrap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "$ref": "#/$defs/httpsUrl" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "signature_url": { "$ref": "#/$defs/httpsUrl" },
        "fingerprint": { "type": "string", "pattern": "^[A-F0-9]{40}$" }
      },
      "required": ["url", "sha256", "signature_url", "fingerprint"]
    }
  }
}
