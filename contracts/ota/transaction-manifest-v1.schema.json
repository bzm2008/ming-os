{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ming.scallion.uno/contracts/ota/transaction-manifest-v1.schema.json",
  "title": "Ming OS transaction manifest v1",
  "x-ming-schema-name": "ming.transaction-manifest.v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ming.transaction-manifest.v1" },
    "release_id": { "$ref": "#/$defs/releaseId" },
    "version": { "$ref": "#/$defs/version" },
    "channel": { "const": "stable" },
    "architecture": { "const": "amd64" },
    "delivery": { "const": "transactional-slot-v1" },
    "from_versions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/version" }
    },
    "minimum_bootstrap": { "$ref": "#/$defs/version" },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "kernel_release": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": { "$ref": "#/$defs/artifact" },
    "content_index": { "$ref": "#/$defs/artifact" },
    "space": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum_free_bytes": { "type": "integer", "minimum": 1 },
        "reserve_bytes": { "type": "integer", "minimum": 0 }
      },
      "required": ["minimum_free_bytes", "reserve_bytes"]
    },
    "slot_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maximum_uncommitted_boots": { "const": 1 },
        "retain_previous_committed_slots": { "const": 1 }
      },
      "required": ["maximum_uncommitted_boots", "retain_previous_committed_slots"]
    },
    "preserve_paths": { "const": ["/home"] },
    "health_profile": { "const": "ming-core-v1" }
  },
  "required": [
    "schema", "release_id", "version", "channel", "architecture", "delivery",
    "from_versions", "minimum_bootstrap", "created_at", "expires_at", "kernel_release",
    "payload", "content_index", "space", "slot_policy", "preserve_paths", "health_profile"
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "releaseId": { "type": "string", "pattern": "^[A-Za-z0-9._-]{8,128}$" },
    "version": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+){1,3}(?:[A-Za-z0-9._-]+)?$" },
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://[^/?#@]+(?:/[^?#]*)?$" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "$ref": "#/$defs/httpsUrl" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 1 },
        "signature_url": { "$ref": "#/$defs/httpsUrl" }
      },
      "required": ["url", "sha256", "size", "signature_url"]
    }
  }
}
